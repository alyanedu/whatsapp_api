PORT=3030
HOST=0.0.0.0
NODE_ENV=development

# Use a long random secret. Send it as X-API-Key.
API_KEY=change-this-long-random-secret

SESSIONS_DIR=./sessions
DATA_DIR=./data

# Pakistan-only OTP gateway.
PAKISTAN_ONLY=true
DEFAULT_COUNTRY_CODE=92

OTP_EXPIRY_MINUTES=5
SESSION_FAILOVER=true
SESSION_FAILURE_LIMIT=3
SESSION_PAUSE_SECONDS=300

# Rate limits are per API instance process.
REQUESTS_PER_MINUTE=60
OTP_REQUESTS_PER_15_MIN=30