PORT=3030
HOST=0.0.0.0
NODE_ENV=development

# Set to 1 when running behind nginx, Caddy, Cloudflare, or another trusted reverse proxy.
TRUST_PROXY=0

# Use a long random secret. Send it as X-API-Key.
API_KEY=change-this-long-random-secret

SESSIONS_DIR=./sessions
DATA_DIR=./data
GATEWAY_CONFIG=./gateway.config.json

# Legacy phone defaults. Prefer gateway.config.json for country rules.
PAKISTAN_ONLY=true
DEFAULT_COUNTRY_CODE=92

OTP_EXPIRY_MINUTES=5
SESSION_FAILOVER=true
SESSION_FAILURE_LIMIT=3
SESSION_PAUSE_SECONDS=300
RECONNECT_BASE_DELAY_SECONDS=10
RECONNECT_MAX_DELAY_SECONDS=300
RECONNECT_MAX_ATTEMPTS=5

# Rate limits are per API instance process.
REQUESTS_PER_MINUTE=60
OTP_REQUESTS_PER_15_MIN=30
MAX_LOG_ENTRIES=200